#!/bin/bash

echo "WARNING: this archived exercise can delete local users."
echo "Set ALLOW_USER_DELETE=1 to continue."
if [ "${ALLOW_USER_DELETE:-}" != "1" ]; then
	echo "Blocked by safety guard."
	exit 1
fi

users=$(awk -F ':' '$6 ~ /^\/home\// { print $1 }' /etc/passwd)
if [ -z "$users" ]; then
	echo "No regular users found."
	exit 0
fi

echo "Available users:"
printf '%s\n' "$users" | nl -w1 -s' '

echo "Choose a user number to delete:"
read -r user_number

del=$(printf '%s\n' "$users" | sed -n "${user_number}p")
if [ -z "$del" ]; then
	echo "Invalid user selection."
	exit 1
fi

echo "Do you really want to delete user '$del'? Continue [Y/n]?"
read -r answer
case "$answer" in
	[yY][eE][sS]|[yY])
		pgrep -u "$del" | while read -r pid; do sudo kill "$pid"; done
		sudo userdel -fr "$del"
		echo "$del has been deleted."
		;;
	[Nn][Oo]|[nN])
		echo "$del was not changed."
		;;
	*)
		echo "Cancelled."
		exit 1
		;;
esac
